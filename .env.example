# Trussflow runtime configuration (dev container defaults).
# Copy to .env or edit in place. See src/trussflow/config.py.

# Memgraph connection. In the dev container the database is the compose
# service named "memgraph"; use "localhost" if running Memgraph on the host.
MEMGRAPH_HOST=memgraph
MEMGRAPH_PORT=7687
# MEMGRAPH_USER=
# MEMGRAPH_PASSWORD=

# LLM provider: "stub" (offline, deterministic) or "copilot" (GitHub Copilot CLI).
TRUSSFLOW_LLM_PROVIDER=stub
# Copilot CLI options (used when TRUSSFLOW_LLM_PROVIDER=copilot).
# Authenticate the CLI headlessly via COPILOT_GITHUB_TOKEN / GH_TOKEN / GITHUB_TOKEN.
# TRUSSFLOW_COPILOT_BINARY=copilot
# TRUSSFLOW_COPILOT_MODEL=gpt-5.4-mini
# TRUSSFLOW_COPILOT_EFFORT=none
# TRUSSFLOW_COPILOT_ALLOW_ALL_TOOLS=true
# TRUSSFLOW_COPILOT_AUTOPILOT=false
# TRUSSFLOW_COPILOT_MAX_AUTOPILOT_CONTINUES=0
# TRUSSFLOW_COPILOT_TIMEOUT=600
# TRUSSFLOW_COPILOT_SESSION_PREFIX=trussflow
# TRUSSFLOW_COPILOT_LOG_DIR=
# TRUSSFLOW_COPILOT_LOG_LEVEL=
# Per-agent overrides (agents: SEED_WRITER, ANALYST, FEATURE_EXTRACTOR,
# WORK_PACKAGER, DECOMPOSER):
# TRUSSFLOW_COPILOT_MODEL_ANALYST=
# TRUSSFLOW_COPILOT_EFFORT_ANALYST=

# Logging: DEBUG, INFO, WARNING, ERROR.
TRUSSFLOW_LOG_LEVEL=INFO

# Orchestration (Prefect agent-flow wrapper). Disabled by default so the
# offline/stub path and tests are unaffected.
# TRUSSFLOW_ORCHESTRATION_ENABLED=false
# TRUSSFLOW_ORCHESTRATION_MAX_REPAIRS=2
# Prefect run-history persistence lives under this directory (gitignored).
# TRUSSFLOW_PREFECT_HOME=.trussflow/prefect
# TRUSSFLOW_PREFECT_PERSIST_RESULTS=true
# Git finalization on a successful step (add -> commit -> push). Push is gated
# off independently so commits stay local unless explicitly enabled.
# TRUSSFLOW_GIT_FINALIZE_ENABLED=false
# TRUSSFLOW_GIT_PUSH_ENABLED=false
# TRUSSFLOW_GIT_REMOTE=origin
# TRUSSFLOW_GIT_BRANCH=
