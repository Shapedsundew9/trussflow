# Trussflow runtime configuration (dev container defaults).
# Copy to .env or edit in place. See src/trussflow/config.py.

# Memgraph connection. In the dev container the database is the compose
# service named "memgraph"; use "localhost" if running Memgraph on the host.
MEMGRAPH_HOST=memgraph
MEMGRAPH_PORT=7687
# MEMGRAPH_USER=
# MEMGRAPH_PASSWORD=

# LLM provider: "stub" (offline, deterministic) or "gemini".
TRUSSFLOW_LLM_PROVIDER=stub
# GEMINI_API_KEY=
# TRUSSFLOW_GEMINI_MODEL=gemini-2.5-flash

# Logging: DEBUG, INFO, WARNING, ERROR.
TRUSSFLOW_LOG_LEVEL=INFO
