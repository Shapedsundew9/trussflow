{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://github.com/Shapedsundew9/trussflow/blob/main/schemas/amendment.schema.json",
    "title": "Trussflow Amendment File",
    "type": "array",
    "minItems": 1,
    "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
            "amendment_id": {
                "type": "string",
                "pattern": "^AMD-[0-9A-Z]+-[0-9]{8}T[0-9]{6}Z$"
            },
            "errata_id": {
                "type": "string",
                "pattern": "^ERR-[0-9A-Z]+-[0-9]{8}T[0-9]{6}Z$"
            },
            "selected_solution_id": {
                "type": "string",
                "enum": [
                    "primary",
                    "alt_1",
                    "alt_2"
                ]
            },
            "approved_by": {
                "type": "string",
                "minLength": 1
            },
            "approval_timestamp": {
                "type": "string",
                "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
            },
            "rationale": {
                "type": "string",
                "minLength": 1
            },
            "changes": {
                "type": "array",
                "minItems": 1,
                "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "change_id": {
                            "type": "string",
                            "pattern": "^CHG-[0-9]{6}$"
                        },
                        "action": {
                            "type": "string",
                            "enum": [
                                "create",
                                "supersede",
                                "state_transition",
                                "scope_change",
                                "ref_update",
                                "move_hierarchy"
                            ]
                        },
                        "target_ruid": {
                            "type": "string",
                            "pattern": "^[0-9A-Z]+[0-3][cpt]$"
                        },
                        "parent_ruid": {
                            "type": "string",
                            "pattern": "^[0-9A-Z]+[0-3][cpt]$"
                        },
                        "new_ruid": {
                            "type": "string",
                            "pattern": "^[0-9A-Z]+[0-3][cpt]$"
                        },
                        "new_timestamp": {
                            "type": "string",
                            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
                        },
                        "supersedes": {
                            "type": "array",
                            "items": {
                                "type": "string",
                                "pattern": "^[0-9A-Z]+$"
                            }
                        },
                        "new_state": {
                            "type": "object",
                            "additionalProperties": false,
                            "properties": {
                                "text": {
                                    "type": "string",
                                    "minLength": 1
                                },
                                "rationale": {
                                    "type": "string",
                                    "minLength": 1
                                },
                                "scope": {
                                    "type": "string",
                                    "enum": [
                                        "in",
                                        "out"
                                    ]
                                },
                                "rs": {
                                    "type": "string",
                                    "enum": [
                                        "c",
                                        "p",
                                        "t"
                                    ]
                                },
                                "refs": {
                                    "type": "object",
                                    "additionalProperties": false,
                                    "properties": {
                                        "depends_on": {
                                            "type": "array",
                                            "items": {
                                                "type": "string",
                                                "pattern": "^[0-9A-Z]+$"
                                            }
                                        },
                                        "related_to": {
                                            "type": "array",
                                            "items": {
                                                "type": "string",
                                                "pattern": "^[0-9A-Z]+$"
                                            }
                                        },
                                        "supersedes": {
                                            "type": "array",
                                            "items": {
                                                "type": "string",
                                                "pattern": "^[0-9A-Z]+$"
                                            }
                                        }
                                    },
                                    "required": [
                                        "depends_on",
                                        "related_to",
                                        "supersedes"
                                    ]
                                }
                            }
                        }
                    },
                    "required": [
                        "change_id",
                        "action"
                    ],
                    "allOf": [
                        {
                            "if": {
                                "properties": {
                                    "action": {
                                        "const": "create"
                                    }
                                }
                            },
                            "then": {
                                "required": [
                                    "parent_ruid",
                                    "new_ruid",
                                    "new_timestamp",
                                    "new_state"
                                ]
                            }
                        },
                        {
                            "if": {
                                "properties": {
                                    "action": {
                                        "const": "supersede"
                                    }
                                }
                            },
                            "then": {
                                "required": [
                                    "target_ruid",
                                    "new_ruid",
                                    "new_timestamp",
                                    "new_state",
                                    "supersedes"
                                ],
                                "properties": {
                                    "supersedes": {
                                        "minItems": 1
                                    }
                                }
                            }
                        },
                        {
                            "if": {
                                "properties": {
                                    "action": {
                                        "enum": [
                                            "state_transition",
                                            "scope_change",
                                            "ref_update",
                                            "move_hierarchy"
                                        ]
                                    }
                                }
                            },
                            "then": {
                                "required": [
                                    "target_ruid",
                                    "new_state"
                                ]
                            }
                        },
                        {
                            "if": {
                                "properties": {
                                    "action": {
                                        "const": "state_transition"
                                    }
                                }
                            },
                            "then": {
                                "properties": {
                                    "new_state": {
                                        "required": [
                                            "rs"
                                        ]
                                    }
                                }
                            }
                        },
                        {
                            "if": {
                                "properties": {
                                    "action": {
                                        "const": "scope_change"
                                    }
                                }
                            },
                            "then": {
                                "properties": {
                                    "new_state": {
                                        "required": [
                                            "scope"
                                        ]
                                    }
                                }
                            }
                        },
                        {
                            "if": {
                                "properties": {
                                    "action": {
                                        "const": "ref_update"
                                    }
                                }
                            },
                            "then": {
                                "properties": {
                                    "new_state": {
                                        "required": [
                                            "refs"
                                        ]
                                    }
                                }
                            }
                        },
                        {
                            "if": {
                                "properties": {
                                    "action": {
                                        "const": "move_hierarchy"
                                    }
                                }
                            },
                            "then": {
                                "required": [
                                    "parent_ruid"
                                ]
                            }
                        }
                    ]
                }
            }
        },
        "required": [
            "amendment_id",
            "errata_id",
            "selected_solution_id",
            "approved_by",
            "approval_timestamp",
            "changes"
        ]
    }
}