{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://trussflow.dev/schemas/errata.schema.json",
    "title": "Trussflow Errata File",
    "type": "array",
    "minItems": 1,
    "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
            "errata_id": {
                "type": "string",
                "pattern": "^ERR-[0-9A-Z]+-[0-9]{8}T[0-9]{6}Z$"
            },
            "discovered_timestamp": {
                "type": "string",
                "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
            },
            "analyst_id": {
                "type": "string",
                "minLength": 1
            },
            "error_type": {
                "type": "string",
                "enum": [
                    "gap",
                    "contradiction",
                    "unverifiable",
                    "irrecoverable_error"
                ]
            },
            "description": {
                "type": "string",
                "minLength": 1
            },
            "affected_ruids": {
                "type": "array",
                "minItems": 1,
                "items": {
                    "type": "string",
                    "pattern": "^[0-9A-Z]+[0-3][cpt]$"
                }
            },
            "violated_rule": {
                "type": "string",
                "enum": [
                    "ruid.uniqueness",
                    "ruid.hierarchy",
                    "rl.constraint",
                    "rs.constraint",
                    "scope.consistency",
                    "ref.dangling",
                    "ref.supersedes_ordering",
                    "text.clarity",
                    "text.verifiability",
                    "text.normative"
                ]
            },
            "root_cause": {
                "type": "string",
                "minLength": 1
            },
            "solutions": {
                "type": "array",
                "minItems": 1,
                "maxItems": 3,
                "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "solution_id": {
                            "type": "string",
                            "enum": [
                                "primary",
                                "alt_1",
                                "alt_2"
                            ]
                        },
                        "action_type": {
                            "type": "string",
                            "enum": [
                                "create_requirement",
                                "update_requirement",
                                "delete_requirement",
                                "state_transition",
                                "scope_change",
                                "supersede",
                                "move_hierarchy"
                            ]
                        },
                        "description": {
                            "type": "string",
                            "minLength": 1
                        },
                        "estimated_affected_count": {
                            "type": "integer",
                            "minimum": 1
                        },
                        "affects_published": {
                            "type": "boolean"
                        },
                        "writer_instructions": {
                            "type": "object",
                            "additionalProperties": false,
                            "properties": {
                                "pseudocode": {
                                    "type": "string",
                                    "minLength": 1
                                },
                                "preconditions": {
                                    "type": "array",
                                    "items": {
                                        "type": "string",
                                        "minLength": 1
                                    }
                                },
                                "validation_hooks": {
                                    "type": "array",
                                    "items": {
                                        "type": "string",
                                        "minLength": 1
                                    }
                                }
                            },
                            "required": [
                                "pseudocode"
                            ]
                        }
                    },
                    "required": [
                        "solution_id",
                        "action_type",
                        "description"
                    ]
                }
            }
        },
        "required": [
            "errata_id",
            "discovered_timestamp",
            "analyst_id",
            "error_type",
            "description",
            "affected_ruids",
            "violated_rule",
            "solutions"
        ]
    }
}